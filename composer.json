{
    "name": "biggercode/evolutiongosdk",
    "description": "SDK for EvolutionGo API",
    "type": "library",
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^10.0|^11.0",
        "illuminate/broadcasting": "^10.0|^11.0",
        "illuminate/foundation": "^10.0|^11.0"
    },
    "autoload": {
        "psr-4": {
            "Biggercode\\EvolutionGoSdk\\": "src/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "extra": {
        "laravel": {
            "providers": [
                "Biggercode\\EvolutionGoSdk\\EvolutionGoSdkServiceProvider"
            ]
        }
    }
}
